<!DOCTYPE html>
<html lang="fi">
<head>
  <meta charset="UTF-8">
  <title>JS Veden Aaltoliike</title>
  <style>
    body {
      margin: 0;
      background: #0f172a;
      color: #f8fafc;
      font-family: system-ui, sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }
    h1 { margin-bottom: 0.5rem; font-size: 1.5rem; }
    p { margin-top: 0; color: #94a3b8; font-size: 0.9rem; }
    canvas {
      border: 2px solid #334155;
      border-radius: 8px;
      cursor: crosshair;
      box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.5);
    }
  </style>
</head>
<body>

  <h1>2D Veden aaltoliike (JavaScript)</h1>
  <p>Molemmat painikkeet toimivat: klikkaa tai vedä hiirellä kankaalla!</p>

  <canvas id="waterCanvas" width="200" height="200" style="width: 500px; height: 500px; image-rendering: pixelated;"></canvas>

  <script>
    const canvas = document.getElementById('waterCanvas');
    const ctx = canvas.getContext('2d');

    const width = canvas.width;
    const height = canvas.height;

    // Luodaan kaksi puskuria veden korkeudelle (nykyinen ja edellinen tila)
    let u = Array.from({ length: width }, () => new Float32Array(height));
    let u_old = Array.from({ length: width }, () => new Float32Array(height));
    let u_new = Array.from({ length: width }, () => new Float32Array(height));

    // Vakioarvot
    const damping = 0.985; // Vaimennus (viskositeetti)
    const c2 = 0.25;       // Aallon nopeuskertoimen neliö

    // ImageData suoraa pikselikäsittelyä varten
    const imgData = ctx.createImageData(width, height);
    const data = imgData.data;

    // Häiriön lisääminen vedenpintaan
    function addDrop(cx, cy, radius, strength) {
      for (let x = -radius; x <= radius; x++) {
        for (let y = -radius; y <= radius; y++) {
          const px = cx + x;
          const py = cy + y;
          if (px > 0 && px < width - 1 && py > 0 && py < height - 1) {
            if (x * x + y * y <= radius * radius) {
              u[px][py] += strength;
            }
          }
        }
      }
    }

    // Numeerisen aalto-yhtälön päivittäminen (FDM)
    function stepSimulation() {
      for (let x = 1; x < width - 1; x++) {
        for (let y = 1; y < height - 1; y++) {
          // 4-pisteen diskreetti Laplace-operaattori
          const laplacian = u[x + 1][y] + u[x - 1][y] + u[x][y + 1] + u[x][y - 1] - 4 * u[x][y];
          
          // Aalto-yhtälön ratkaisu
          u_new[x][y] = (2 * u[x][y] - u_old[x][y] + c2 * laplacian) * damping;
        }
      }

      // Vaihdetaan puskureiden rooleja (Zero-allocation swap)
      const temp = u_old;
      u_old = u;
      u = u_new;
      u_new = temp;
    }

    // Visualisointi Canvasille
    function render() {
      let idx = 0;
      for (let y = 0; y < height; y++) {
        for (let x = 0; x < width; x++) {
          const val = u[x][y];

          // Värjätään aallonharjat kirkkaan sinisiksi ja suvannot tummiksi
          const r = Math.min(255, Math.max(0, 10 + val * 2));
          const g = Math.min(255, Math.max(0, 100 + val * 8));
          const b = Math.min(255, Math.max(0, 180 + val * 12));

          data[idx]     = r;   // R
          data[idx + 1] = g;   // G
          data[idx + 2] = b;   // B
          data[idx + 3] = 255; // Alpha
          idx += 4;
        }
      }
      ctx.putImageData(imgData, 0, 0);
    }

    // Pääsilmukka
    function loop() {
      stepSimulation();
      render();
      requestAnimationFrame(loop);
    }

    // Hiiriohjaus
    let isMouseDown = false;

    function handleInput(e) {
      const rect = canvas.getBoundingClientRect();
      const scaleX = width / rect.width;
      const scaleY = height / rect.height;

      const x = Math.floor((e.clientX - rect.left) * scaleX);
      const y = Math.floor((e.clientY - rect.top) * scaleY);

      addDrop(x, y, 3, 40);
    }

    canvas.addEventListener('mousedown', (e) => { isMouseDown = true; handleInput(e); });
    canvas.addEventListener('mousemove', (e) => { if (isMouseDown) handleInput(e); });
    window.addEventListener('mouseup', () => { isMouseDown = false; });

    // Aloitetaan peli silmukka
    loop();
  </script>
</body>
</html>
